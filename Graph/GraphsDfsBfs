}

class WaterJugFill {
    int jug1Qty;
    int jug2Qty;
    int steps;
    WaterJugFill(int jug1Qty, int jug2Qty, int steps){
        this.jug1Qty=jug1Qty;
        this.jug2Qty=jug2Qty;
        this.steps=steps;
    }
}
class Coordinates{
    int x;
    int y;
    Coordinates(int x,int y){
        this.x=x;
        this.y=y;
    }
}

class KnightSteps{
    Coordinates coordinates;
    int steps;
    KnightSteps(Coordinates coordinates, int steps){
        this.coordinates=coordinates;
        this.steps=steps;
    }
}

class Cell{
    int index;
    int distance;
    Cell(int index, int distance){
        this.index=index;
        this.distance=distance;
    }
}
